{
  "compilerOptions": {
    "target": "ES2020",
    "module": "none",
    "ignoreDeprecations": "6.0",
    "strict": true,
    "rootDir": "static",
    "outDir": "build",
    "noEmitOnError": true,
    "skipLibCheck": true,
    "lib": ["DOM", "ES2020"]
  },
  "include": ["static/**/*.ts"]
}
